# Required: Google Gemini API Key
# Get it from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Telegram Bot for notifications
# Get bot token from: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: Your Telegram Chat ID for notifications
# Get it by sending a message to your bot and checking: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: Todoist API for shopping lists
# Get it from: https://todoist.com/app/settings/integrations
TODOIST_API_KEY=your_todoist_api_key_here